# ========================================
# Pub-IA - Variables d'environnement
# ========================================
# Copier ce fichier vers .env et remplir les valeurs
# cp .env.example .env

# ========================================
# Flask Backend
# ========================================
FLASK_ENV=development
FLASK_DEBUG=0
SECRET_KEY=change-me-in-production-use-random-64-chars-here
FLASK_PORT=8000

# ========================================
# Base de données PostgreSQL
# ========================================
POSTGRES_DB=pubia
POSTGRES_USER=pubia
POSTGRES_PASSWORD=pubia_secure_password_change_me
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://pubia:pubia_secure_password_change_me@db:5432/pubia

# ========================================
# Redis
# ========================================
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ========================================
# OpenAI (pour la détection d'intention)
# ========================================
# OU utiliser Ollama (voir ci-dessous)
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-proj-xxx_change_me
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT=8
OPENAI_MAX_TOKENS=150

# ========================================
# Ollama (alternative à OpenAI)
# ========================================
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=https://ollama.com
# OLLAMA_API_KEY=your-ollama-api-key
# OLLAMA_MODEL=llama3.2

# ========================================
# Google OAuth2
# ========================================
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxx
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ========================================
# Pub-IA Configuration
# ========================================
PUBIA_INTENT_THRESHOLD=0.65
PUBIA_PUBLISHER_SHARE=0.70
PUBIA_MIN_PAYOUT=50.00

# ========================================
# Frontend URL (pour CORS)
# ========================================
FRONTEND_URL=http://localhost:5173

# ========================================
# Ports
# ========================================
CADDY_PORT=8080
DEMO_PORT=3000

# ========================================
# Demo Chatbot
# ========================================
DEMO_API_KEY=pk_live_demo_key_change_me

# ========================================
# Sentry (production uniquement)
# ========================================
SENTRY_DSN=https://xxx@sentry.io/xxx

# ========================================
# Environment
# ========================================
PUBIA_ENV=development
PUBIA_DEBUG=1
