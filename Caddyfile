:80 {
    handle /api/* {
        reverse_proxy backend:8000
    }

    handle /v1/* {
        reverse_proxy backend:8000
    }

    handle /auth/* {
        reverse_proxy backend:8000
    }

    handle /health {
        reverse_proxy backend:8000
    }

    handle /* {
        reverse_proxy frontend:5173
    }

    encode gzip

    header {
        Strict-Transport-Security max-age=31536000
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy no-referrer-when-downgrade
    }
}
